# Work Hub — environment variables. Copy to .env.local and fill in real values.
# These are set in the Vercel project (Settings -> Environment Variables) for
# production. Never commit real secrets.

# --- Auth (required) ---
# Password for the login gate (api/login.js).
APP_PASSWORD=change-me
# Secret used to sign/verify HMAC session tokens (lib/auth.js). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# --- Anthropic (required) ---
# Server-side key for the agent proxy (api/agent.js). Never exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# --- Postgres (required for the EOD snapshot / morning-brief feature) ---
# Read by @vercel/postgres. From Vercel Dashboard -> Storage -> your DB -> .env.local tab.
POSTGRES_URL=postgres://user:password@host:5432/dbname

# --- Optional ---
# Custom origin allowed for CORS on api/agent.js. Defaults to the Vercel deployment URL.
# ALLOWED_ORIGIN=https://your-domain.com
# VAPID public key for Web Push (lib/notifications.js, build-time via Vite).
# VITE_VAPID_PUBLIC_KEY=
